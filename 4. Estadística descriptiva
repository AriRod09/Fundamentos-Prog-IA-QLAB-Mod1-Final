.4)\n","\n","# ── Gráfico 2: Área urbano / rural ─────────────────────\n","ax = axes[0, 1]\n","base_final['area'] = base_final['ESTRATO'].apply(\n","    lambda x: 'Urbano' if pd.notna(x) and x <= 6 else ('Rural' if pd.notna(x) else np.nan)\n",")\n","area_counts = base_final.groupby('area')['FACTOR07'].sum()\n","area_pct = area_counts / area_counts.sum() * 100\n","\n","colores_area = [\"#2166ac\", \"#74add1\"]\n","wedges, texts, autotexts = ax.pie(\n","    area_pct.values,\n","    labels=area_pct.index,\n","    autopct='%1.1f%%',\n","    colors=colores_area,\n","    startangle=90,\n","    wedgeprops={'edgecolor': 'white', 'linewidth': 1.5}\n",")\n","for at in autotexts:\n","    at.set_fontsize(10)\n","ax.set_title(\"Distribución por área (urbano/rural)\", fontsize=11, fontweight='bold')\n","\n","# ── Gráfico 3: Sexo ────────────────────────────────────\n","ax = axes[1, 0]\n","sexo_map = {1: 'Hombre', 2: 'Mujer'}\n","sexo_counts = base_final.groupby('P207')['FACTOR07'].sum().rename(index=sexo_map)\n","sexo_counts = sexo_counts[sexo_counts.index != 0.0] # Exclude 0.0 category\n","sexo_pct = sexo_counts / sexo_counts.sum() * 100\n","\n","colores_sexo = [\"#4393c3\", \"#d6604d\"]\n","etiquetas = sexo_pct.index.tolist()  # ['Hombre', 'Mujer']\n","valores   = sexo_pct.values\n","\n","# Usar posiciones numéricas en lugar de strings directamente\n","x_pos = range(len(etiquetas))\n","bars = ax.bar(x_pos, valores, color=colores_sexo, edgecolor='white', width=0.5)\n","\n","# Poner las etiquetas en el eje X manualmente\n","ax.set_xticks(x_pos)\n","ax.set_xticklabels(etiquetas, fontsize=10)\n","\n","for bar, val in zip(bars, valores):\n","    ax.text(bar.get_x() + bar.get_width()/2, val + 0.5,\n","f\"{val:.1f}%\",\n","            ha='center', fontsize=10, fontweight='bold')\n","\n","ax.set_title(\"Distribución por sexo\", fontsize=11, fontweight='bold')\n","ax.set_ylabel(\"% de personas (ponderado)\")\n","ax.set_ylim(0, 60)\n","ax.spines[[\"top\", \"right\", \"left\"]].set_visible(False)\n","ax.grid(axis='y', linestyle='--', alpha=0.4)\n","\n","# ── Gráfico 4: Distribución de edad ───────────────────\n","ax = axes[1, 1]\n","edades = base_final.dropna(subset=['P208A'])\n","ax.hist(\n","    edades['P208A'],\n","    bins=20,\n","    weights=edades['FACTOR07'],\n","    color=color_base,\n","    edgecolor='white',\n","    linewidth=0.5\n",")\n","media_edad = np.average(edades['P208A'], weights=edades['FACTOR07'])\n","ax.axvline(media_edad, color='tomato', linestyle='--', linewidth=1.2,\n","           label=f'Media: {media_edad:.1f} años')\n","ax.set_title(\"Distribución por edad\", fontsize=11, fontweight='bold')\n","ax.set_xlabel(\"Edad (años)\")\n","ax.set_ylabel(\"Frecuencia ponderada\")\n","ax.legend(fontsize=9)\n","ax.spines[[\"top\", \"right\"]].set_visible(False)\n","ax.grid(axis='y', linestyle='--', alpha=0.4)\n","\n","fig.suptitle(\"Descripción de la muestra (2020–2024)\",\n","             fontsize=13, fontweight='bold', y=1.01)\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"2GKuu5Uy1WMf","executionInfo":{"status":"ok","timestamp":1775567988425,"user_tz":300,"elapsed":3775,"user":{"displayName":"Diego Alonso Canales Becerra","userId":"11688558320895341146"}},"outputId":"b06c2c4d-692c-4274-e99d-00bcb1bad61a"},"execution_count":13,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x1000 with 4 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["**Distribución por nivel educactivo**\n","\n","La distribución ponderada de la muestra para el período 2020–2024 muestra una fuerte concentración en niveles educativos básicos y medios. El grupo más numeroso corresponde a personas con secundaria completa (23.0%), seguido por quienes tienen primaria incompleta (18.6%) y secundaria incompleta (15.2%), lo que indica que una parte importante de la población se ubica en trayectorias educativas intermedias o no concluidas. En contraste, los niveles de educación superior presentan proporciones menores: 6.6% cuenta con educación superior no universitaria completa, 6.1% con superior universitaria completa y solo 1.0% con maestría o doctorado. Asimismo, se observa que 5.7% de la población no tiene nivel educativo y 4.6% se ubica en educación inicial, lo que sugiere que la base incluye tanto población adulta como menores de edad.\n","\n","En conjunto, este patrón evidencia una estructura educativa heterogénea, pero con predominio de niveles no superiores, aspecto relevante para el análisis posterior, dado que el nivel educativo puede influir en el acceso a información, el aprovechamiento de la cobertura y el uso efectivo de los servicios de salud.\n","\n","**Distribución pro área (urbano / Rural)**\n","\n","La distribución ponderada de la muestra evidencia un claro predominio de población residente en áreas urbanas, que representa el 82.8% del total, frente a un 17.2% correspondiente al ámbito rural. Esta composición sugiere que la muestra se concentra mayoritariamente en contextos urbanos, donde suelen existir mayores niveles de oferta de servicios, infraestructura y conectividad. No obstante, la proporción rural sigue siendo relevante para el análisis, ya que permite captar diferencias en el acceso a la atención y en las condiciones territoriales que podrían influir tanto en la utilización de servicios como en el gasto de bolsillo en salud.\n","\n","**Distribución por sexo**\n","\n","La distribución ponderada de la muestra por sexo muestra una composición bastante equilibrada, aunque con un ligero predominio de mujeres, que representan el 51.5% del total, frente al 48.5% de hombres. Esta diferencia es reducida, por lo que no se observa un sesgo marcado en la estructura de la muestra según sexo. En términos analíticos, esta composición resulta adecuada para el estudio, ya que permite comparar resultados entre hombres y mujeres sin una desproporción importante en la representación de ambos grupos. Asimismo, la presencia de una categoría residual de 0.0% sugiere la existencia de registros sin peso o sin clasificación efectiva, pero su magnitud es nula y no afecta la lectura general del gráfico.\n","\n","**Distribución por edad**\n","\n","La distribución ponderada de la muestra por edad muestra una concentración importante en población joven y adulta, con una media de 34.2 años. La mayor frecuencia se observa en los tramos de edades tempranas e intermedias, especialmente entre la niñez, adolescencia y adultez joven, mientras que a partir de los 60 años la frecuencia disminuye progresivamente. Esto sugiere que la muestra está compuesta mayoritariamente por personas en edades potencialmente activas, tanto en términos educativos como laborales, lo que resulta consistente con el análisis de variables como nivel educativo, informalidad y acceso a servicios de salud. Al mismo tiempo, la presencia de personas en edades avanzadas permite captar diferencias relevantes en necesidades de atención y gasto en salud a lo largo del ciclo de vida, aunque este grupo tenga un peso relativo menor dentro de la muestra total."],"metadata":{"id":"_PVPR6PxPDQM"}},{"cell_type":"markdown","metadata":{"id":"KFMu5qa-6hFU"},"source":["## 4.2. Variable dependiente"]},{"cell_type":"markdown","source":["**Histograma de la distribución del gasto**"],"metadata":{"id":"Q3LuiVWU8ui-"}},{"cell_type":"code","source":["base_final['GASTO_BOLSILLO'] = pd.to_numeric(base_final['GASTO_BOLSILLO'], errors='coerce').fillna(0)\n","base_final['log_gasto']      = np.log(base_final['GASTO_BOLSILLO'] + 1)"],"metadata":{"id":"P3kF5RKk3B6L","executionInfo":{"status":"ok","timestamp":1775568044336,"user_tz":300,"elapsed":42,"user":{"displayName":"Diego Alonso Canales Becerra","userId":"11688558320895341146"}}},"execution_count":14,"outputs":[]},{"cell_type":"code","source":["fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n","\n","# Panel izquierdo — distribución original\n","ax = axes[0]\n","gasto_pos = base_final[base_final['GASTO_BOLSILLO'] > 0]['GASTO_BOLSILLO']\n","ax.hist(gasto_pos, bins=60, color=\"#2166ac\", edgecolor='white', linewidth=0.4)\n","ax.axvline(gasto_pos.mean(),   color='tomato',  linestyle='--', linewidth=1.2,\n","           label=f\"Media: S/. {gasto_pos.mean():,.1f}\")\n","ax.axvline(gasto_pos.median(), color='orange', linestyle='--', linewidth=1.2,\n","           label=f\"Mediana: S/. {gasto_pos.median():,.1f}\")\n","ax.set_title(\"Distribución original del gasto\\n(solo personas con gasto > 0)\",\n","             fontsize=11, fontweight='bold')\n","ax.set_xlabel(\"Gasto de bolsillo (S/.)\")\n","ax.set_ylabel(\"Frecuencia\")\n","ax.legend(fontsize=9)\n","ax.spines[[\"top\", \"right\"]].set_visible(False)\n","ax.grid(axis='y', linestyle='--', alpha=0.4)\n","\n","# Panel derecho — log(gasto+1) sobre toda la muestra\n","ax = axes[1]\n","ax.hist(base_final['log_gasto'], bins=60, color=\"#4393c3\", edgecolor='white', linewidth=0.4)\n","ax.axvline(base_final['log_gasto'].mean(),   color='tomato',  linestyle='--', linewidth=1.2,\n","           label=f\"Media: {base_final['log_gasto'].mean():.2f}\")\n","ax.axvline(base_final['log_gasto'].median(), color='orange', linestyle='--', linewidth=1.2,\n","           label=f\"Mediana: {base_final['log_gasto'].median():.2f}\")\n","ax.set_title(\"Distribución log(gasto + 1)\\n(muestra completa, incluyendo ceros)\",\n","             fontsize=11, fontweight='bold')\n","ax.set_xlabel(\"log(Gasto de bolsillo + 1)\")\n","ax.set_ylabel(\"Frecuencia\")\n","ax.legend(fontsize=9)\n","ax.spines[[\"top\", \"right\"]].set_visible(False)\n","ax.grid(axis='y', linestyle='--', alpha=0.4)\n","\n","fig.suptitle(\"Distribución del gasto de bolsillo en salud (2020–2024)\",\n","             fontsize=13, fontweight='bold', y=1.01)\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":526},"id":"jNsrXp9n3G_W","executionInfo":{"status":"ok","timestamp":1775568057212,"user_tz":300,"elapsed":1595,"user":{"displayName":"Diego Alonso Canales Becerra","userId":"11688558320895341146"}},"outputId":"c5492fd1-1c9f-45d4-bde0-5fffe1b27f03"},"execution_count":15,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x500 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["**Distribución original del gasto (solo personas con gasto > 0)**\n","\n","La distribución original del gasto de bolsillo en salud, considerando únicamente a las personas con gasto mayor a cero, muestra una marcada asimetría positiva. La mayor parte de los casos se concentra en montos relativamente bajos, mientras que existe un grupo mucho menor de personas con gastos muy elevados que extiende la cola de la distribución hacia la derecha. Esto se refleja claramente en la diferencia entre la mediana (S/ 256.0) y la media (S/ 865.8): mientras la mediana indica que la mitad de quienes realizaron algún gasto desembolsó hasta un monto moderado, la media se eleva de manera importante por la presencia de valores extremos. En términos analíticos, este patrón sugiere que el gasto de bolsillo no se distribuye de forma homogénea entre la población, sino que recae con mucha mayor intensidad en un subconjunto reducido de personas, lo que resulta consistente con la idea de que ciertos hogares enfrentan episodios de gasto particularmente altos frente a necesidades de salud más complejas o menos cubiertas por el sistema.\n","\n","**Distribución log(gasto + 1) (muestra completa, incluyendo ceros)**\n","\n","La distribución de la variable transformada log(gasto de bolsillo + 1), construida sobre la muestra completa e incluyendo a las personas con gasto igual a cero, muestra una fuerte concentración de observaciones en el valor 0. Esto indica que una parte importante de la población no registró gasto de bolsillo en salud durante el período analizado, lo que se refleja también en una mediana de 0.00. Sin embargo, la media de 1.60 y la presencia de una cola hacia la derecha evidencian que existe otro grupo de personas que sí realizó desembolsos, con montos de magnitud variable. En ese sentido, este gráfico permite observar simultáneamente dos rasgos centrales del fenómeno: por un lado, la alta frecuencia de personas sin gasto y, por otro, la heterogeneidad entre quienes sí incurrieron en pagos directos. Por ello, la transformación logarítmica resulta útil para reducir la asimetría de la distribución original y facilitar un análisis estadístico más estable del gasto de bolsillo en salud."],"metadata":{"id":"pC26q0OyWVEq"}},{"cell_type":"markdown","source":["**Proporción con gasto = 0 vs gasto > 0**"],"metadata":{"id":"KYAPj-6Z4HZq"}},{"cell_type":"code","source":["fig, ax = plt.subplots(figsize=(7, 5))\n","\n","n_cero   = (base_final['GASTO_BOLSILLO'] == 0).sum()\n","n_pos    = (base_final['GASTO_BOLSILLO'] >  0).sum()\n","total    = len(base_final)\n","\n","etiquetas = ['Gasto = 0\\n(no desembolsó)', 'Gasto > 0\\n(sí desembolsó)']\n","valores   = [n_cero / total * 100, n_pos / total * 100]\n","colores   = [\"#b2182b\", \"#2166ac\"]\n","\n","bars = ax.bar([0, 1], valores, color=colores, edgecolor='white', width=0.5)\n","ax.set_xticks([0, 1])\n","ax.set_xticklabels(etiquetas, fontsize=11)\n","\n","for bar, val, n in zip(bars, valores, [n_cero, n_pos]):\n","    ax.text(bar.get_x() + bar.get_width()/2, val + 0.5,\n","            f\"{val:.1f}%\\n(n = {n:,})\",\n","            ha='center', fontsize=10, fontweight='bold')\n","\n","ax.set_title(\"Proporción de personas con y sin gasto de bolsillo (2020–2024)\",\n","             fontsize=12, fontweight='bold')\n","ax.set_ylabel(\"% de personas en la muestra\")\n","ax.set_ylim(0, max(valores) + 10)\n","ax.spines[[\"top\", \"right\", \"left\"]].set_visible(False)\n","ax.grid(axis='y', linestyle='--', alpha=0.4)\n","\n","plt.tight_layout()\n","plt.show()\n","\n","print(f\"Personas con gasto = 0 : {n_cero:,} ({n_cero/total:.1%})\")\n","print(f\"Personas con gasto > 0 : {n_pos:,